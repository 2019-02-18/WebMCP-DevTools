{
  "name": "webmcp-devtools",
  "description": "WebMCP DevTools - A Chrome extension for debugging WebMCP tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "typescript": "^5.8.0",
    "wxt": "^0.20.0"
  }
}
