## 九、消息协议

所有跨层通信使用统一消息格式：

// Main World 转 Content Script (via window.postMessage)
interface WebMCPDevToolsEvent {
  type: 'WEBMCP_DEVTOOLS_EVENT';
  event: 'REGISTER_TOOL' | 'UNREGISTER_TOOL' | 'TOOL_CHANGE' | 'TOOLS_LIST';
  timestamp: number;
  data: any;
}

// Content Script 和 Service Worker 和 Side Panel (via chrome.runtime)
interface ChromeMessage {
  action: 'LIST_TOOLS' | 'EXECUTE_TOOL' | 'TOOL_EVENT' | 'GET_SNAPSHOTS' | 'SAVE_SNAPSHOT' | 'DELETE_SNAPSHOT';
  payload?: any;
}

// 工具定义（通信用，不含 execute 回调）
interface ToolInfo {
  name: string;
  description: string;
  inputSchema?: string;
  annotations?: { readOnlyHint?: boolean };
}

// 时间线事件
interface TimelineEvent {
  id: string;
  timestamp: number;
  type: 'register' | 'unregister' | 'toolchange';
  toolName: string;
  data?: ToolInfo;
}

// 快照
interface Snapshot {
  id: string;
  name: string;
  url: string;
  timestamp: number;
  tools: ToolInfo[];
}

// 执行历史
interface ExecutionRecord {
  id: string;
  toolName: string;
  input: any;
  output: any;
  duration: number;
  timestamp: number;
  success: boolean;
}

